# LLM API Keys (at least one required)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Telegram Bot (optional — enables Telegram channel integration)
# Create a bot via @BotFather on Telegram, then paste the token here
TELEGRAM_BOT_TOKEN=

# Database (defaults to SQLite — no setup needed)
# DATABASE_URL=sqlite+aiosqlite:///./agents.db
